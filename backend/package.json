{
  "name": "@seum/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/migrate.ts",
    "migrate:phase1": "tsx src/migrate-phase1.ts",
    "migrate:run": "tsx src/run-migrations.ts",
    "fix:missing-tables": "tsx src/scripts/fix-missing-tables.ts",
    "migrate:create": "npx node-pg-migrate create --migration-file-language ts",
    "seed": "tsx src/seed.ts",
    "setup-supabase": "tsx src/setup-supabase.ts",
    "setup": "npm run setup-supabase && npm run seed",
    "cleanup-audit-logs": "tsx src/scripts/cleanup-audit-logs.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests"
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
