# Supabase PostgreSQL (use one connection string)
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.xxxxxxx.supabase.co:5432/postgres

# JWT Secrets (64-char hex each)
JWT_ACCESS_SECRET=generate-a-random-64-char-string
JWT_REFRESH_SECRET=generate-a-different-random-64-char-string

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=90

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
